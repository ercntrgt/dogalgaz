@page "/profil"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Profilim</PageTitle>

<h2 class="mb-3">Profilim</h2>

@if (user is null)
{
    <p>Yükleniyor...</p>
}
else
{
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card summary-box">
                <div class="card-header bg-white fw-semibold">Hesap</div>
                <div class="card-body">
                    <div class="mb-2"><span class="text-muted">Ad Soyad:</span> <strong>@user.FullName</strong></div>
                    <div class="mb-2"><span class="text-muted">E-posta:</span> @user.Email</div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card summary-box">
                <div class="card-header bg-white fw-semibold"><i class="bi bi-vector-pen"></i> İmza-Kaşe</div>
                <div class="card-body">
                    <p class="small text-muted">Hazırladığın tekliflerin PDF'inde "Firma Yetkilisi İmza" alanına bu görsel basılır.</p>
                    <InputFile class="form-control mb-2" OnChange="OnFile" accept="image/png,image/jpeg" />
                    @if (!string.IsNullOrEmpty(stampData))
                    {
                        <div class="my-2"><img src="@stampData" style="max-height:90px;max-width:100%;border:1px solid #e3e7ee;border-radius:8px;background:#fff" /></div>
                    }
                    <div class="d-flex gap-2">
                        <button class="btn btn-success" @onclick="Save">💾 Kaydet</button>
                        @if (!string.IsNullOrEmpty(stampData))
                        {
                            <button class="btn btn-outline-danger" @onclick="Remove">Kaldır</button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(msg)) { <div class="small text-success mt-2">@msg</div> }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private ApplicationUser? user;
    private string? stampData;
    private string? msg;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) return;
        var name = (await AuthState).User.Identity?.Name;
        if (name is not null) user = await UserManager.FindByEmailAsync(name);
        stampData = user?.SignatureStamp;
    }

    private async Task OnFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        using var ms = new MemoryStream();
        await file.OpenReadStream(3 * 1024 * 1024).CopyToAsync(ms);
        stampData = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
        msg = null;
    }

    private async Task Save()
    {
        if (user is null) return;
        user.SignatureStamp = stampData;
        await UserManager.UpdateAsync(user);
        msg = "İmza-kaşe kaydedildi.";
    }

    private async Task Remove()
    {
        if (user is null) return;
        user.SignatureStamp = null;
        stampData = null;
        await UserManager.UpdateAsync(user);
        msg = "İmza-kaşe kaldırıldı.";
    }
}
