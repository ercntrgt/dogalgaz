@page "/services"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using TesisatTeklifApp.Domain.Constants
@inject IServiceRecordService ServiceService
@inject NavigationManager Nav

<PageTitle>Servis Kayıtları</PageTitle>

<div class="d-flex align-items-center mb-3">
    <h2 class="mb-0">Servis Kayıtları</h2>
    <a href="services/new" class="btn btn-success ms-auto"><i class="bi bi-plus-circle"></i> Yeni Servis</a>
</div>

<div class="card summary-box mb-3">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label small mb-0">Ara (servis no / müşteri / cihaz)</label>
            <input class="form-control form-control-sm" @bind="filter.Keyword" @bind:after="Load" />
        </div>
        <div class="col-md-3">
            <label class="form-label small mb-0">Durum</label>
            <select class="form-select form-select-sm" @bind="statusSel" @bind:after="Load">
                <option value="">Tümü</option>
                <option value="0">Yeni</option>
                <option value="1">Randevu Verildi</option>
                <option value="2">Tamamlandı</option>
                <option value="3">İptal</option>
            </select>
        </div>
        <div class="col-md-2"><label class="form-label small mb-0">Başlangıç</label><input type="date" class="form-control form-control-sm" @bind="filter.FromDate" @bind:after="Load" /></div>
        <div class="col-md-2"><label class="form-label small mb-0">Bitiş</label><input type="date" class="form-control form-control-sm" @bind="filter.ToDate" @bind:after="Load" /></div>
    </div>
</div>

<div class="card summary-box">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Servis No</th><th>Tarih</th><th>Müşteri</th><th>Cihaz</th><th>Nedeni</th><th>Durum</th><th class="text-end">Tutar</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in list)
                {
                    <tr>
                        <td class="fw-semibold">@s.ServiceNumber</td>
                        <td>@s.ApplicationDate.ToString("dd.MM.yyyy")</td>
                        <td>@(s.Customer?.FullName ?? s.CustomerName ?? "-")</td>
                        <td>@DeviceText(s)</td>
                        <td class="small">@ServiceReasonLabels.Text(s.ServiceReasons)</td>
                        <td>@StatusBadge(s.Status)</td>
                        <td class="text-end">@s.TotalAmount.ToString("#,##0.00") ₺</td>
                        <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="services/@s.Id">Aç</a></td>
                    </tr>
                }
                @if (list.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Servis kaydı yok.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<ServiceRecord> list = new();
    private ServiceRecordFilter filter = new();
    private string? statusSel;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        filter.Status = string.IsNullOrEmpty(statusSel) ? null : (ServiceStatus)int.Parse(statusSel);
        list = await ServiceService.SearchAsync(filter);
    }

    private static string DeviceText(ServiceRecord s)
    {
        var d = $"{s.DeviceBrand} {s.DeviceModel} {s.DeviceType}".Trim();
        return string.IsNullOrWhiteSpace(d) ? "-" : d;
    }

    private RenderFragment StatusBadge(ServiceStatus st) => builder =>
    {
        var (cls, txt) = st switch
        {
            ServiceStatus.Yeni => ("bg-info", "Yeni"),
            ServiceStatus.RandevuVerildi => ("bg-warning text-dark", "Randevu"),
            ServiceStatus.Tamamlandi => ("bg-success", "Tamamlandı"),
            _ => ("bg-secondary", "İptal")
        };
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"badge {cls}");
        builder.AddContent(2, txt);
        builder.CloseElement();
    };
}
