@page "/teklif/{Token}"
@layout EmptyLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using TesisatTeklifApp.Domain.Constants
@inject IOfferService OfferService
@inject IJSRuntime JS

<PageTitle>Teklif Onayı — ÖZDEMİR Mühendislik</PageTitle>

<div class="pub-wrap">
    <div class="pub-card">
        @if (loading)
        {
            <p class="text-center text-muted py-5">Yükleniyor...</p>
        }
        else if (offer is null)
        {
            <div class="text-center py-5">
                <i class="bi bi-exclamation-triangle text-warning" style="font-size:2.5rem"></i>
                <h5 class="mt-3">Teklif bulunamadı</h5>
                <p class="text-muted">Bağlantı geçersiz veya süresi dolmuş olabilir.</p>
            </div>
        }
        else
        {
            <div class="text-center mb-3">
                <img src="images/logo.png" alt="ÖZDEMİR" style="max-height:56px" onerror="this.style.display='none'" />
                <h4 class="mt-2 mb-0" style="color:#1a3a6b">Teklif Onayı</h4>
                <div class="text-muted small">Form No: @offer.OfferNumber • @offer.OfferDate.ToString("dd.MM.yyyy")</div>
            </div>

            <div class="pub-info mb-3">
                <div><strong>Sayın:</strong> @(offer.Customer?.FullName ?? "Müşterimiz)")</div>
                @if (!string.IsNullOrWhiteSpace(offer.Customer?.Address))
                {
                    <div class="text-muted small">@offer.Customer!.Address</div>
                }
            </div>

            <h6 class="pub-sec">İşin Kapsamı</h6>
            @foreach (var grp in ItemsByGroup)
            {
                <div class="pub-group">
                    <div class="pub-group-head">@grp.Key</div>
                    @foreach (var it in grp.Value)
                    {
                        <div class="pub-line">
                            <span>@it.ItemName</span>
                            <span class="text-muted">@FormatQty(it.Quantity) @it.Unit</span>
                        </div>
                    }
                </div>
            }
            @if (Radiators.Any())
            {
                <div class="pub-group">
                    <div class="pub-group-head">RADYATÖR & VANA</div>
                    @foreach (var r in Radiators)
                    {
                        <div class="pub-line">
                            <span>
                                @if (r.IsValve)
                                {
                                    @(r.ItemName ?? "Vana")
                                }
                                else
                                {
                                    @($"{r.RoomName} {r.RadiatorHeight}x{r.RadiatorWidth}".Trim())
                                }
                            </span>
                            <span class="text-muted">@FormatQty(r.Quantity) @(r.IsValve ? "adet" : "adet panel")</span>
                        </div>
                    }
                </div>
            }

            <div class="pub-total">
                <span>GENEL TOPLAM</span>
                <span>@offer.GrandTotal.ToString("#,##0.00") ₺</span>
            </div>

            @if (offer.AdvancePayment > 0 || Installments.Any())
            {
                <h6 class="pub-sec mt-4">Ödeme Planı</h6>
                @if (offer.AdvancePayment > 0)
                {
                    <div class="pub-line">
                        <span><strong>Peşinat</strong></span>
                        <span>@offer.AdvancePayment.ToString("#,##0.00") ₺</span>
                    </div>
                }
                @foreach (var (p, i) in Installments.Select((p, i) => (p, i + 1)))
                {
                    <div class="pub-line">
                        <span>
                            @i. Taksit — @PaymentTypeText.Label(p.PaymentType)
                            @if (p.PaymentDate.HasValue)
                            {
                                <span class="text-muted small">(@p.PaymentDate!.Value.ToString("dd.MM.yyyy"))</span>
                            }
                        </span>
                        <span>@p.Amount.ToString("#,##0.00") ₺</span>
                    </div>
                }
            }

            @if (offer.CustomerApprovedDate is not null || approved)
            {
                <div class="pub-approved">
                    <i class="bi bi-check-circle-fill"></i>
                    <div>
                        <div class="fw-semibold">Teklif onaylandı</div>
                        <div class="small text-muted">@((offer.CustomerApprovedDate ?? DateTime.Now).ToString("dd.MM.yyyy HH:mm")) — imzanız kaydedildi.</div>
                    </div>
                </div>
                <a class="btn btn-outline-primary w-100 mt-2" href="/teklif/@Token/pdf" target="_blank">
                    <i class="bi bi-file-earmark-pdf"></i> Teklifi PDF indir
                </a>
            }
            else
            {
                <h6 class="pub-sec mt-4">Onay ve İmza</h6>
                <p class="small text-muted mb-2">Teklifi onaylamak için aşağıdaki alana imzanızı atıp "Onayla" butonuna basın.</p>
                <div class="sig-box">
                    <canvas id="sigCanvas" class="sig-canvas"></canvas>
                </div>
                <div class="d-flex gap-2 mt-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSig">Temizle</button>
                    <button class="btn btn-success ms-auto" @onclick="Approve" disabled="@saving">
                        <i class="bi bi-check2-circle"></i> @(saving ? "Kaydediliyor..." : "Onayla ve İmzala")
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(msg))
                {
                    <div class="alert alert-warning py-2 mt-2 mb-0 small">@msg</div>
                }
            }
        }
    </div>
    <div class="text-center text-white-50 small mt-3">ÖZDEMİR Mühendislik Mekanik Tesisat</div>
</div>

<style>
    body { background: linear-gradient(160deg, #1a3a6b, #12233f); }
    .pub-wrap { max-width: 560px; margin: 0 auto; padding: 20px 14px 40px; }
    .pub-card { background: #fff; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,.25); padding: 22px; }
    .pub-info { background: #f7f9fc; border-radius: 10px; padding: 10px 12px; }
    .pub-sec { color: #1a3a6b; font-weight: 700; border-bottom: 2px solid #eef3fb; padding-bottom: 4px; }
    .pub-group { margin-bottom: 10px; }
    .pub-group-head { font-size: .78rem; font-weight: 700; color: #5b6573; letter-spacing: .3px; margin: 6px 0 2px; }
    .pub-line { display: flex; justify-content: space-between; padding: 5px 2px; border-bottom: 1px solid #f1f3f7; font-size: .92rem; }
    .pub-total { display: flex; justify-content: space-between; align-items: center; background: #1a3a6b; color: #fff; border-radius: 12px; padding: 14px 16px; font-size: 1.15rem; font-weight: 700; margin-top: 14px; }
    .sig-box { border: 2px dashed #b9c4d6; border-radius: 12px; background: #fcfdff; }
    .sig-canvas { width: 100%; height: 180px; touch-action: none; display: block; }
    .pub-approved { display: flex; align-items: center; gap: 10px; background: #eaf7ee; border: 1px solid #b6e0c2; border-radius: 12px; padding: 12px 14px; margin-top: 14px; }
    .pub-approved i { color: #198754; font-size: 1.6rem; }
</style>

@code {
    [Parameter] public string Token { get; set; } = "";

    private Offer? offer;
    private bool loading = true;
    private bool saving;
    private bool approved;
    private bool padInit;
    private string? msg;

    private IEnumerable<KeyValuePair<string, List<OfferItem>>> ItemsByGroup =>
        (offer?.Items ?? new List<OfferItem>())
            .Where(i => i.IsSelected && i.Quantity > 0)
            .GroupBy(i => string.IsNullOrEmpty(i.GroupName) ? "DİĞER" : i.GroupName!)
            .Select(g => new KeyValuePair<string, List<OfferItem>>(g.Key, g.ToList()));

    private IEnumerable<PaymentPlan> Installments =>
        (offer?.PaymentPlans ?? new List<PaymentPlan>()).Where(p => p.Amount > 0);

    private IEnumerable<RadiatorItem> Radiators =>
        (offer?.RadiatorItems ?? new List<RadiatorItem>()).Where(r => r.Quantity > 0);

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(Token))
            offer = await OfferService.GetByPublicTokenAsync(Token);
        loading = false;
    }

    // Tuval yalnızca veri yüklendikten sonra oluştuğu için firstRender tek başına yetmez;
    // bayrakla tek sefer kurulur. Aksi halde her render pad'i sıfırlayıp çizimi siliyordu.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!padInit && offer is not null && offer.CustomerApprovedDate is null && !approved)
        {
            await JS.InvokeVoidAsync("signaturePad.init", "sigCanvas");
            padInit = true;
        }
    }

    private async Task ClearSig() => await JS.InvokeVoidAsync("signaturePad.clear", "sigCanvas");

    private async Task Approve()
    {
        msg = null;
        var empty = await JS.InvokeAsync<bool>("signaturePad.isEmpty", "sigCanvas");
        if (empty) { msg = "Lütfen önce imzanızı atın."; return; }
        saving = true;
        var data = await JS.InvokeAsync<string?>("signaturePad.getData", "sigCanvas");
        if (string.IsNullOrEmpty(data)) { msg = "İmza alınamadı, tekrar deneyin."; saving = false; return; }
        await OfferService.ApproveByTokenAsync(Token, data);
        approved = true;
        saving = false;
    }

    private static string FormatQty(decimal v) => v % 1 == 0 ? v.ToString("0") : v.ToString("0.##");
}
