@page "/offers/new"
@page "/offers/{Id:int}/edit"
@attribute [Authorize(Roles = "Admin,SalesPerson")]
@rendermode InteractiveServer
@inject IOfferService OfferService
@inject ICustomerService CustomerService
@inject IProductService ProductService
@inject IUstaService UstaService
@inject IOfferCalculationService Calc
@inject IAuditService Audit
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(IsNew ? "Yeni Teklif" : offer.OfferNumber)</PageTitle>

@if (loading)
{
    <p>Yükleniyor...</p>
}
else
{
    <div class="offer-form @(pricesHidden ? "prices-hidden" : "")">
    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
        <h2 class="mb-0">@(IsNew ? "Yeni Teklif / Sipariş" : $"Teklif — {offer.OfferNumber}")</h2>
        <span><StatusBadge Status="offer.Status" /></span>
        <button type="button" class="btn btn-sm @(pricesHidden ? "btn-outline-secondary" : "btn-warning") ms-auto"
                @onclick="() => pricesHidden = !pricesHidden">
            <i class="bi @(pricesHidden ? "bi-eye-slash" : "bi-eye")"></i>
            @(pricesHidden ? "Fiyatlar Gizli" : "Fiyatlar Görünür")
        </button>
    </div>

    @* A) Müşteri Bilgileri *@
    <div class="card summary-box mb-3">
        <div class="card-header bg-white fw-semibold">A) Müşteri Bilgileri</div>
        <div class="card-body row g-3">
            <div class="col-md-4">
                <label class="form-label">Müşteri *</label>
                @if (IsNew)
                {
                    <div class="input-group">
                        <select class="form-select" @bind="offer.CustomerId">
                            <option value="0">-- müşteri seçin --</option>
                            @foreach (var c in customers)
                            {
                                <option value="@c.Id">@c.FullName — @c.Phone</option>
                            }
                        </select>
                        <button type="button" class="btn btn-outline-primary" @onclick="ToggleNewCustomer"
                                title="Yeni müşteri ekle">@(showNewCustomer ? "✕" : "➕ Yeni")</button>
                    </div>
                }
                else
                {
                    <input class="form-control" value="@selectedCustomer?.FullName" disabled />
                }
            </div>
            <div class="col-md-2">
                <label class="form-label">Form No</label>
                <input class="form-control" value="@(IsNew ? "(otomatik)" : offer.OfferNumber)" disabled />
            </div>
            <div class="col-md-3">
                <label class="form-label">Teklif Tarihi</label>
                <input type="date" class="form-control" @bind="offer.OfferDate" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Sorumlu Personel</label>
                <input class="form-control" @bind="offer.ResponsiblePerson" />
            </div>

            @if (IsNew && showNewCustomer)
            {
                <div class="col-12">
                    <div class="border rounded p-3 bg-light">
                        <div class="d-flex align-items-center mb-2">
                            <h6 class="mb-0">Yeni Müşteri</h6>
                            @if (!string.IsNullOrEmpty(customerError))
                            {
                                <span class="text-danger ms-3 small">@customerError</span>
                            }
                        </div>
                        <div class="row g-2">
                            <div class="col-md-3"><input class="form-control form-control-sm" placeholder="Ad *" @bind="newCustomer.FirstName" /></div>
                            <div class="col-md-3"><input class="form-control form-control-sm" placeholder="Soyad *" @bind="newCustomer.LastName" /></div>
                            <div class="col-md-3"><input class="form-control form-control-sm" placeholder="Telefon" @bind="newCustomer.Phone" /></div>
                            <div class="col-md-3"><input class="form-control form-control-sm" placeholder="T.C. Kimlik No" maxlength="11" @bind="newCustomer.NationalId" /></div>
                            <div class="col-md-3"><input class="form-control form-control-sm" placeholder="İl" @bind="newCustomer.City" /></div>
                            <div class="col-md-3"><input class="form-control form-control-sm" placeholder="İlçe" @bind="newCustomer.District" /></div>
                            <div class="col-md-6"><input class="form-control form-control-sm" placeholder="Adres" @bind="newCustomer.Address" /></div>
                        </div>
                        <div class="mt-2">
                            <button type="button" class="btn btn-sm btn-success" @onclick="SaveNewCustomer">💾 Müşteriyi Kaydet ve Seç</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleNewCustomer">Vazgeç</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* B) Ürünler — Excel grup başlıkları altında akordeon *@
    <div class="card summary-box mb-3">
        <div class="card-header bg-white fw-semibold d-flex align-items-center">
            <span>B) Ürün / Kalem Seçimi</span>
            <span class="ms-2 text-muted small">— gruba tıklayın, ürünü seçip ekleyin</span>
        </div>
        <div class="card-body">
            @foreach (var g in OfferGroups.All)
            {
                @if (g.IsRadiator)
                {
                    <RadiatorSection Items="offer.RadiatorItems" RadiatorProducts="radiatorProducts" ValveProducts="valveProducts" OnChanged="Recalc" />
                }
                else
                {
                    <OfferGroupSection Group="g" AllItems="offer.Items"
                                       Products="ProductsForGroup(g)" OnChanged="Recalc" />
                }
            }
        </div>
    </div>

    @* G) Genel Açıklamalar *@
    <div class="card summary-box mb-3">
        <div class="card-header bg-white fw-semibold">G) Genel Açıklamalar</div>
        <div class="card-body">
            <textarea class="form-control" rows="2" @bind="offer.GeneralNotes"></textarea>
        </div>
    </div>

    <div class="row g-3">
        @* H) Fiyatlandırma Özeti *@
        <div class="col-lg-6">
            @if (pricesHidden)
            {
                <div class="card summary-box mb-3">
                    <div class="card-body text-center text-muted py-4">
                        <i class="bi bi-eye-slash fs-3"></i>
                        <p class="mb-1 mt-2">Fiyatlar gizli.</p>
                        <button type="button" class="btn btn-sm btn-warning" @onclick="() => pricesHidden = false">
                            <i class="bi bi-eye"></i> Fiyatları Göster
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="card summary-box mb-3">
                    <div class="card-header bg-white fw-semibold">H) Fiyatlandırma Özeti</div>
                    <div class="card-body">
                        <table class="table table-sm mb-2">
                            <tbody>
                                <tr><td>Kombi / Kazan / Klima / Isı P.</td><td class="text-end">@Money(offer.KombiKazanTotal)</td></tr>
                                <tr><td>Doğalgaz / Kolon Tesisatı</td><td class="text-end">@Money(offer.GasInstallationTotal)</td></tr>
                                <tr><td>Malzeme / Ekipman</td><td class="text-end">@Money(offer.MaterialTotal)</td></tr>
                                <tr><td>Radyatör</td><td class="text-end">@Money(offer.RadiatorTotal)</td></tr>
                                <tr><td>Kalorifer Tesisatı</td><td class="text-end">@Money(offer.InstallationTotal)</td></tr>
                                <tr><td>İşçilik</td><td class="text-end">@Money(offer.LaborTotal)</td></tr>
                                <tr class="border-top"><td class="fw-semibold">Ara Toplam</td><td class="text-end fw-semibold">@Money(offer.SubTotal)</td></tr>
                            </tbody>
                        </table>
                        <div class="row g-2 align-items-center mb-2">
                            <div class="col-7">İskonto Oranı (%)</div>
                            <div class="col-5">
                                <input type="number" step="any" class="form-control form-control-sm" @bind="offer.DiscountRate" @bind:after="Recalc" />
                            </div>
                            <div class="col-7 text-muted">İskonto Tutarı</div>
                            <div class="col-5 text-end">@Money(offer.DiscountAmount)</div>
                            <div class="col-7">Ek Oranlar (%)</div>
                            <div class="col-5">
                                <input type="number" step="any" class="form-control form-control-sm" @bind="offer.VatRate" @bind:after="Recalc" />
                            </div>
                            <div class="col-7">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input" id="vatinc" @bind="offer.IsVatIncluded" @bind:after="Recalc" />
                                    <label class="form-check-label" for="vatinc">Fiyatlara dahil</label>
                                </div>
                            </div>
                            <div class="col-5 text-end text-muted">Ek Oranlar: @Money(offer.VatAmount)</div>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2">
                            <span class="fw-bold fs-5">Genel Toplam</span>
                            <span class="fw-bold fs-5 text-primary">@Money(offer.GrandTotal)</span>
                        </div>
                        <div class="row g-2 align-items-center mt-1">
                            <div class="col-7">Peşinat</div>
                            <div class="col-5">
                                <input type="number" step="any" class="form-control form-control-sm" @bind="offer.AdvancePayment" @bind:after="Recalc" />
                            </div>
                            <div class="col-7 fw-semibold">Kalan Ödeme</div>
                            <div class="col-5 text-end fw-semibold">@Money(offer.RemainingPayment)</div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* I) Ödeme Planı + J) İş Programı *@
        <div class="col-lg-6">
            <div class="card summary-box mb-3 price-cell">
                <div class="card-header bg-white fw-semibold">I) Ödeme Planı (Taksitler / Vadeler)</div>
                <div class="card-body">
                    @* Ödeme yöntemi en üstte — taksitler bu yönteme göre üretilir *@
                    <div class="mb-3">
                        <label class="form-label small mb-1 fw-semibold">Ödeme Yöntemi</label>
                        <select class="form-select form-select-sm" @bind="offer.PaymentMethod" @bind:after="OnPaymentMethodChanged">
                            @foreach (var t in PaymentTypes.Selectable)
                            {
                                <option value="@t">@PaymentTypeText.Label(t)</option>
                            }
                        </select>
                    </div>

                    @* Otomatik eşit taksit bölme *@
                    <div class="row g-2 align-items-end mb-3 p-2 rounded" style="background:#f4f6f9;">
                        <div class="col-auto">
                            <label class="form-label small mb-0">Taksit sayısı</label>
                            <input type="number" min="1" max="60" class="form-control form-control-sm" style="width:88px"
                                   @bind="installmentCount" @bind:after="GenerateInstallments" />
                        </div>
                        <div class="col-auto">
                            <label class="form-label small mb-0">Periyot</label>
                            <select class="form-select form-select-sm" style="width:108px" @bind="installmentPeriod" @bind:after="GenerateInstallments">
                                <option value="Ay">Aylık</option>
                                <option value="Hafta">Haftalık</option>
                                <option value="Gün">Günlük</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="GenerateInstallments">
                                <i class="bi bi-calculator"></i> Eşit Taksitlere Böl
                            </button>
                        </div>
                    </div>

                    @if (offer.PaymentPlans.Count > 0)
                    {
                        <div class="row g-2 mb-1 text-muted small fw-semibold d-none d-md-flex">
                            <div class="col-md-3">Ödeme Türü</div>
                            <div class="col-md-3">Tutar (₺)</div>
                            <div class="col-md-3">Vade Tarihi</div>
                            <div class="col-md-2">Açıklama</div>
                            <div class="col-md-1"></div>
                        </div>
                    }
                    @foreach (var pp in offer.PaymentPlans)
                    {
                        <div class="row g-2 mb-2 align-items-center">
                            <div class="col-md-3">
                                <select class="form-select form-select-sm" @bind="pp.PaymentType">
                                    @foreach (var t in PaymentTypes.Selectable)
                                    {
                                        <option value="@t">@PaymentTypeText.Label(t)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <input type="number" step="any" class="form-control form-control-sm" @bind="pp.Amount" @bind:after="StateHasChanged" placeholder="0,00" />
                            </div>
                            <div class="col-md-3">
                                <input type="date" class="form-control form-control-sm" @bind="pp.PaymentDate" />
                            </div>
                            <div class="col-md-2">
                                <input class="form-control form-control-sm" @bind="pp.Description" placeholder="örn. 1. taksit" />
                            </div>
                            <div class="col-md-1 text-end">
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="@(() => offer.PaymentPlans.Remove(pp))">×</button>
                            </div>
                        </div>
                    }
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddPayment">➕ Taksit / Vade Ekle</button>

                    <div class="border-top mt-3 pt-2 small">
                        <div class="d-flex justify-content-between fw-semibold"><span>Peşinat + Taksitler:</span><span>@Money(offer.AdvancePayment + offer.PaymentPlans.Sum(p => p.Amount))</span></div>
                        <div class="d-flex justify-content-between @(PlanDiff == 0 ? "text-success" : "text-danger")">
                            <span>Genel Toplam ile fark:</span><span>@Money(PlanDiff)</span>
                        </div>
                    </div>
                </div>
            </div>

            @* J) İş Programı + Usta *@
            <div class="card summary-box mb-3">
                <div class="card-header bg-white fw-semibold">J) İş Programı & Usta</div>
                <div class="card-body row g-3">
                    <div class="col-md-6">
                        <label class="form-label">İş Başlangıç Tarihi</label>
                        <input type="date" class="form-control" @bind="offer.WorkStartDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">İş Teslim Tarihi</label>
                        <input type="date" class="form-control" @bind="offer.WorkEndDate" />
                    </div>
                    <div class="col-md-7">
                        <label class="form-label">Usta (iş bazlı)</label>
                        <div class="input-group">
                            <select class="form-select" @bind="offer.UstaId">
                                <option value="">-- usta seçin --</option>
                                @foreach (var u in ustalar)
                                {
                                    <option value="@u.Id">@u.Name @(string.IsNullOrEmpty(u.Specialty) ? "" : $"({u.Specialty})")</option>
                                }
                            </select>
                            <button type="button" class="btn btn-outline-primary" @onclick="ToggleNewUsta"
                                    title="Yeni usta ekle">@(showNewUsta ? "✕" : "➕")</button>
                        </div>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Usta Hakedişi (₺)</label>
                        <input type="number" step="any" class="form-control" @bind="offer.UstaEarning" />
                        <div class="form-text">İç bilgi — müşteriye görünmez.</div>
                    </div>
                    @if (showNewUsta)
                    {
                        <div class="col-12">
                            <div class="border rounded p-2 bg-light d-flex gap-2 align-items-center">
                                <input class="form-control form-control-sm" style="max-width:220px" placeholder="Usta adı *" @bind="newUstaName" />
                                <input class="form-control form-control-sm" style="max-width:160px" placeholder="Uzmanlık" @bind="newUstaSpecialty" />
                                <button type="button" class="btn btn-sm btn-success" @onclick="SaveNewUsta">Kaydet ve Seç</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger">@error</div>
    }

    <div class="d-flex gap-2 mb-5 sticky-bottom bg-light py-2">
        <button class="btn btn-success" @onclick="Save">💾 Kaydet</button>
        <a href="offers" class="btn btn-outline-secondary">İptal</a>
        @if (!IsNew)
        {
            <a href="offers/@offer.Id" class="btn btn-outline-primary ms-auto">Detay Görünümü</a>
        }
    </div>
    </div>
}

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromQuery] public int? CustomerId { get; set; }

    private bool IsNew => Id is null;
    private bool loading = true;
    private bool pricesHidden = false;  // satışçı kalem fiyatlarını görür (müşteri PDF/link fiyatsız)
    private string? error;

    private Offer offer = new();
    private List<Customer> customers = new();
    private List<Product> allProducts = new();
    private List<Product> radiatorProducts = new();
    private List<Product> valveProducts = new();
    private List<Usta> ustalar = new();
    private Customer? selectedCustomer;

    private List<Product> ProductsForGroup(OfferGroup g) =>
        allProducts.Where(p => g.Categories.Contains(p.Category)).ToList();

    private bool showNewCustomer;
    private Customer newCustomer = new();
    private string? customerError;

    private bool showNewUsta;
    private string newUstaName = "";
    private string? newUstaSpecialty;

    protected override async Task OnInitializedAsync()
    {
        allProducts = await ProductService.GetActiveAsync();
        radiatorProducts = allProducts.Where(p => p.Category == ProductCategories.Radyator).ToList();
        valveProducts = allProducts.Where(p => OfferGroups.ValveCategories.Contains(p.Category)).ToList();
        customers = await CustomerService.SearchAsync(new CustomerSearchFilter());
        ustalar = await UstaService.GetActiveAsync();

        if (Id is int id)
        {
            offer = await OfferService.GetByIdAsync(id) ?? new Offer();
            selectedCustomer = offer.Customer;
        }
        else
        {
            offer = NewDraft();
            if (CustomerId is int cid) offer.CustomerId = cid;
        }
        BackfillGroups();
        loading = false;
    }

    // Eski kayıtlar / varsayılan kalemler için GroupName'i doldurur (grup akordeonunda görünsün).
    private void BackfillGroups()
    {
        foreach (var it in offer.Items.Where(i => string.IsNullOrEmpty(i.GroupName)))
        {
            OfferGroup? g = null;
            if (it.ProductId is int pid)
            {
                var cat = allProducts.FirstOrDefault(p => p.Id == pid)?.Category;
                g = OfferGroups.ForCategory(cat);
            }
            g ??= OfferGroups.All.FirstOrDefault(x => x.Section == it.SectionName && !x.IsRadiator);
            if (g is not null) it.GroupName = g.Name;
        }
    }

    private Offer NewDraft()
        // Boş taslak; kalemler grup akordeonundan ("Grubu Ekle" / tek tek) eklenir.
        => new() { OfferDate = DateTime.Today, Status = OfferStatus.Draft, VatRate = 30m };

    private void Recalc()
    {
        Calc.RecalculateOfferTotals(offer);
        StateHasChanged();
    }

    private void AddPayment() => offer.PaymentPlans.Add(new PaymentPlan { PaymentType = offer.PaymentMethod });

    private int installmentCount = 3;
    private string installmentPeriod = "Ay";

    private decimal InstallmentBase =>
        (offer.GrandTotal - offer.AdvancePayment) > 0 ? offer.GrandTotal - offer.AdvancePayment : offer.GrandTotal;

    /// <summary>Yöntem değişince mevcut taksitlerin türünü de günceller; taksit sayısını yönteme göre önerir.</summary>
    private void OnPaymentMethodChanged()
    {
        foreach (var p in offer.PaymentPlans) p.PaymentType = offer.PaymentMethod;

        // Peşin yöntemlerde tek ödeme, vadeli yöntemlerde 3 taksit mantıklı bir başlangıç.
        installmentCount = offer.PaymentMethod switch
        {
            PaymentType.Cash or PaymentType.BankTransfer => 1,
            _ => 3
        };
        StateHasChanged();
    }

    private async Task GenerateInstallments()
    {
        var n = installmentCount;
        if (n < 1) return;

        // Elle girilmiş satırlar varsa üzerine yazmadan önce onay al.
        var manual = offer.PaymentPlans.Any(p => string.IsNullOrEmpty(p.Description) || !p.Description!.EndsWith(". taksit"));
        if (manual && !await JS.InvokeAsync<bool>("confirm",
                "Ödeme planındaki mevcut satırlar silinip yeniden oluşturulacak. Devam edilsin mi?"))
            return;

        var total = InstallmentBase;
        var per = Math.Round(total / n, 2, MidpointRounding.AwayFromZero);
        var today = DateTime.Today;

        offer.PaymentPlans.Clear();
        for (var i = 0; i < n; i++)
        {
            var date = installmentPeriod switch
            {
                "Hafta" => today.AddDays(7 * i),
                "Gün" => today.AddDays(i),
                _ => today.AddMonths(i)
            };
            var amount = i == n - 1 ? Math.Round(total - per * (n - 1), 2) : per;
            offer.PaymentPlans.Add(new PaymentPlan
            {
                PaymentType = offer.PaymentMethod, Amount = amount, PaymentDate = date, Description = $"{i + 1}. taksit"
            });
        }
        StateHasChanged();
    }

    private void ToggleNewCustomer()
    {
        showNewCustomer = !showNewCustomer;
        customerError = null;
        if (showNewCustomer) newCustomer = new Customer();
    }

    private async Task SaveNewCustomer()
    {
        customerError = null;
        if (string.IsNullOrWhiteSpace(newCustomer.FirstName) || string.IsNullOrWhiteSpace(newCustomer.LastName))
        {
            customerError = "Ad ve soyad zorunludur.";
            return;
        }
        await CustomerService.AddAsync(newCustomer);
        customers = await CustomerService.SearchAsync(new CustomerSearchFilter());
        offer.CustomerId = newCustomer.Id;
        showNewCustomer = false;
    }

    private void ToggleNewUsta()
    {
        showNewUsta = !showNewUsta;
        if (showNewUsta) { newUstaName = ""; newUstaSpecialty = null; }
    }

    private async Task SaveNewUsta()
    {
        if (string.IsNullOrWhiteSpace(newUstaName)) return;
        var u = new Usta { Name = newUstaName.Trim(), Specialty = newUstaSpecialty, IsActive = true };
        await UstaService.AddAsync(u);
        ustalar = await UstaService.GetActiveAsync();
        offer.UstaId = u.Id;
        showNewUsta = false;
    }

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private async Task<string> CurrentUser()
    {
        if (AuthState is null) return "bilinmiyor";
        return (await AuthState).User.Identity?.Name ?? "bilinmiyor";
    }

    private async Task Save()
    {
        error = null;
        if (offer.CustomerId <= 0) { error = "Lütfen bir müşteri seçin."; return; }
        try
        {
            var isNew = offer.Id == 0;
            if (isNew && string.IsNullOrEmpty(offer.CreatedBy))
                offer.CreatedBy = await CurrentUser();
            await OfferService.SaveAsync(offer);
            await Audit.LogAsync("Offer", offer.Id, isNew ? "Teklif oluşturuldu" : "Teklif güncellendi", await CurrentUser());
            Nav.NavigateTo($"offers/{offer.Id}");
        }
        catch (Exception ex)
        {
            error = "Kayıt sırasında hata: " + ex.Message;
        }
    }

    private decimal PlanDiff => offer.GrandTotal - (offer.AdvancePayment + offer.PaymentPlans.Sum(p => p.Amount));

    private static string Money(decimal v) => v.ToString("#,##0.00") + " ₺";
}
