@page "/admin/veri-temizle"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IDataResetService ResetService

<PageTitle>Veri Temizliği</PageTitle>

<h2 class="mb-3">Teslim Öncesi Veri Temizliği</h2>

<div class="alert alert-danger">
    <strong><i class="bi bi-exclamation-octagon"></i> Bu işlem geri alınamaz.</strong>
    Aşağıdaki kayıtlar kalıcı olarak silinir. <strong>Ürünler, kullanıcılar ve ayarlar korunur.</strong>
</div>

@if (counts is null)
{
    <p class="text-muted">Yükleniyor...</p>
}
else if (done)
{
    <div class="alert alert-success">
        <strong>Temizlik tamamlandı.</strong> Silinen kayıtlar:
        <ul class="mb-0 mt-2">
            <li>Müşteriler: @counts.Customers</li>
            <li>Teklif / Sipariş: @counts.Offers (ödeme planı: @counts.PaymentPlans)</li>
            <li>Servis kayıtları: @counts.ServiceRecords</li>
            <li>Ustalar: @counts.Ustalar (hakediş: @counts.UstaPayments)</li>
            <li>Satınalma: @counts.PurchaseOrders — Tedarikçiler: @counts.Suppliers</li>
            <li>Stok hareketleri: @counts.StockMovements — İşlem geçmişi: @counts.ActivityLogs</li>
        </ul>
    </div>
    <div class="alert alert-info mb-0">
        <strong>@counts.Products ürün</strong> korundu@(zeroStock ? ", stok ve rezerve miktarları sıfırlandı" : ", rezerve miktarları sıfırlandı").
        Sistem teslime hazır.
    </div>
}
else
{
    <div class="card summary-box mb-3">
        <div class="card-header bg-white fw-semibold">Silinecek kayıtlar</div>
        <div class="card-body">
            <table class="table table-sm mb-0" style="max-width:420px">
                <tbody>
                    <tr><td>Müşteriler</td><td class="text-end fw-semibold">@counts.Customers</td></tr>
                    <tr><td>Teklif / Sipariş</td><td class="text-end fw-semibold">@counts.Offers</td></tr>
                    <tr><td>Ödeme planı satırları</td><td class="text-end fw-semibold">@counts.PaymentPlans</td></tr>
                    <tr><td>Servis kayıtları</td><td class="text-end fw-semibold">@counts.ServiceRecords</td></tr>
                    <tr><td>Ustalar</td><td class="text-end fw-semibold">@counts.Ustalar</td></tr>
                    <tr><td>Hakediş ödemeleri</td><td class="text-end fw-semibold">@counts.UstaPayments</td></tr>
                    <tr><td>Satınalma siparişleri</td><td class="text-end fw-semibold">@counts.PurchaseOrders</td></tr>
                    <tr><td>Tedarikçiler</td><td class="text-end fw-semibold">@counts.Suppliers</td></tr>
                    <tr><td>Stok hareketleri</td><td class="text-end fw-semibold">@counts.StockMovements</td></tr>
                    <tr><td>İşlem geçmişi</td><td class="text-end fw-semibold">@counts.ActivityLogs</td></tr>
                    <tr class="table-light"><td class="fw-bold">Toplam</td><td class="text-end fw-bold">@counts.Total</td></tr>
                </tbody>
            </table>
            <div class="mt-3 small text-success">
                <i class="bi bi-shield-check"></i> Korunacak: <strong>@counts.Products ürün</strong>, tüm kullanıcı hesapları ve ayarlar.
            </div>
        </div>
    </div>

    <div class="card summary-box">
        <div class="card-body">
            <div class="form-check mb-3">
                <input type="checkbox" class="form-check-input" id="zs" @bind="zeroStock" />
                <label class="form-check-label" for="zs">Ürünlerin stok miktarlarını da sıfırla</label>
            </div>

            <label class="form-label small">Onaylamak için kutuya <strong>SİL</strong> yazın:</label>
            <input class="form-control mb-3" style="max-width:220px" @bind="confirmText" @bind:event="oninput" placeholder="SİL" />

            <button class="btn btn-danger" disabled="@(!CanPurge || busy)" @onclick="Purge">
                <i class="bi bi-trash3"></i> @(busy ? "Siliniyor..." : "Kayıtları Kalıcı Olarak Sil")
            </button>
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger mt-3 mb-0">@error</div>
            }
        </div>
    </div>
}

@code {
    private DataResetCounts? counts;
    private string? confirmText;
    private bool zeroStock = true;
    private bool busy, done;
    private string? error;

    private bool CanPurge => string.Equals(confirmText?.Trim(), "SİL", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync() => counts = await ResetService.GetCountsAsync();

    private async Task Purge()
    {
        if (!CanPurge) return;
        busy = true; error = null;
        try
        {
            counts = await ResetService.PurgeAsync(zeroStock);
            done = true;
        }
        catch (Exception ex)
        {
            error = "Silme sırasında hata: " + ex.Message;
        }
        busy = false;
    }
}
