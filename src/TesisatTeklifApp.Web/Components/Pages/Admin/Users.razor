@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Kullanıcılar</PageTitle>

<h2 class="mb-3">Kullanıcı Yönetimi</h2>

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card summary-box">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead><tr><th>Ad</th><th>E-posta</th><th>Rol</th><th>Durum</th></tr></thead>
                    <tbody>
                        @foreach (var u in users)
                        {
                            <tr>
                                <td>@u.User.FullName</td>
                                <td>@u.User.Email</td>
                                <td><span class="badge bg-primary">@AppRoles.DisplayName(u.Role)</span></td>
                                <td>@(u.User.IsActive ? "Aktif" : "Pasif")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card summary-box">
            <div class="card-header bg-white fw-semibold">Yeni Kullanıcı</div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(msg))
                {
                    <div class="alert @(ok ? "alert-success" : "alert-danger") py-2">@msg</div>
                }
                <div class="mb-2">
                    <label class="form-label">Ad Soyad</label>
                    <input class="form-control" @bind="newFullName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">E-posta</label>
                    <input class="form-control" @bind="newEmail" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Şifre</label>
                    <input type="password" class="form-control" @bind="newPassword" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Rol</label>
                    <select class="form-select" @bind="newRole">
                        @foreach (var r in AppRoles.All)
                        {
                            <option value="@r">@AppRoles.DisplayName(r)</option>
                        }
                    </select>
                </div>
                <button class="btn btn-success" @onclick="Create">➕ Oluştur</button>
            </div>
        </div>
    </div>
</div>

<div class="card summary-box mt-3">
    <div class="card-header bg-white fw-semibold"><i class="bi bi-vector-pen"></i> İmza-Kaşe (Teklif PDF'inde "Firma Yetkilisi İmza")</div>
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Kullanıcı</label>
            <select class="form-select" @bind="stampUserId" @bind:after="LoadStamp">
                <option value="">-- kullanıcı seç --</option>
                @foreach (var u in users)
                {
                    <option value="@u.User.Id">@u.User.FullName (@u.User.Email)</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">İmza-Kaşe PNG/JPG</label>
            <InputFile class="form-control" OnChange="OnStampFile" accept="image/png,image/jpeg" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-success" @onclick="SaveStamp" disabled="@(string.IsNullOrEmpty(stampUserId))">💾 Kaydet</button>
        </div>
        <div class="col-md-2 text-center">
            @if (!string.IsNullOrEmpty(stampData))
            {
                <img src="@stampData" style="max-height:60px;max-width:100%;border:1px solid #e3e7ee;border-radius:6px" />
            }
        </div>
        @if (!string.IsNullOrEmpty(stampMsg)) { <div class="col-12 small text-success">@stampMsg</div> }
    </div>
</div>

@code {
    private record UserRow(ApplicationUser User, string Role);
    private List<UserRow> users = new();

    private string newFullName = "", newEmail = "", newPassword = "", newRole = AppRoles.SalesPerson;
    private string? msg;
    private bool ok;

    private string stampUserId = "";
    private string? stampData;
    private string? stampMsg;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        users = new();
        foreach (var u in UserManager.Users.ToList())
        {
            var roles = await UserManager.GetRolesAsync(u);
            users.Add(new UserRow(u, roles.FirstOrDefault() ?? "-"));
        }
    }

    private async Task LoadStamp()
    {
        stampMsg = null; stampData = null;
        if (string.IsNullOrEmpty(stampUserId)) return;
        var u = await UserManager.FindByIdAsync(stampUserId);
        stampData = u?.SignatureStamp;
    }

    private async Task OnStampFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        using var ms = new MemoryStream();
        await file.OpenReadStream(3 * 1024 * 1024).CopyToAsync(ms);   // maks 3 MB
        stampData = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";
    }

    private async Task SaveStamp()
    {
        stampMsg = null;
        var u = await UserManager.FindByIdAsync(stampUserId);
        if (u is null) return;
        u.SignatureStamp = stampData;
        await UserManager.UpdateAsync(u);
        stampMsg = "İmza-kaşe kaydedildi.";
    }

    private async Task Create()
    {
        msg = null;
        var user = new ApplicationUser { UserName = newEmail, Email = newEmail, EmailConfirmed = true, FullName = newFullName, IsActive = true };
        var result = await UserManager.CreateAsync(user, newPassword);
        if (result.Succeeded)
        {
            await UserManager.AddToRoleAsync(user, newRole);
            ok = true; msg = "Kullanıcı oluşturuldu.";
            newFullName = newEmail = newPassword = "";
            await Load();
        }
        else
        {
            ok = false; msg = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }
}
