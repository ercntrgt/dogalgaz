@page "/admin/stock-movements"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@using TesisatTeklifApp.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db

<PageTitle>Stok Hareketleri</PageTitle>

<h2 class="mb-3">Stok Hareket Geçmişi</h2>

<div class="card summary-box">
    <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr><th>Tarih</th><th>Ürün</th><th>Tür</th><th class="text-end">Miktar</th><th class="text-end">Önceki</th><th class="text-end">Yeni</th><th>Müşteri / Belge</th><th>Açıklama</th></tr>
            </thead>
            <tbody>
                @foreach (var m in movements)
                {
                    <tr>
                        <td>@m.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@m.Product?.Name</td>
                        <td><span class="badge @TypeClass(m.MovementType)">@TypeLabel(m.MovementType)</span></td>
                        <td class="text-end">@m.Quantity.ToString("0.##")</td>
                        <td class="text-end">@m.PreviousStock.ToString("0.##")</td>
                        <td class="text-end">@m.NewStock.ToString("0.##")</td>
                        <td>
                            @if (m.Offer is not null)
                            {
                                <span>@(m.Offer.Customer?.FullName ?? "-")</span>
                                <br /><a class="small text-muted" href="offers/@m.OfferId">@(m.Offer.OrderNumber ?? m.Offer.OfferNumber)</a>
                            }
                            else { <span class="text-muted">-</span> }
                        </td>
                        <td class="small text-muted">@m.Description</td>
                    </tr>
                }
                @if (movements.Count == 0)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Henüz stok hareketi yok.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<StockMovement> movements = new();

    protected override async Task OnInitializedAsync()
    {
        movements = await Db.StockMovements
            .Include(m => m.Product)
            .Include(m => m.Offer).ThenInclude(o => o!.Customer)
            .OrderByDescending(m => m.CreatedDate)
            .Take(300)
            .ToListAsync();
    }

    private string TypeLabel(MovementType t) => t switch
    {
        MovementType.Out => "Çıkış",
        MovementType.In => "Giriş",
        MovementType.Reserve => "Rezerve",
        MovementType.Restore => "İade",
        _ => t.ToString()
    };

    private string TypeClass(MovementType t) => t switch
    {
        MovementType.Out => "bg-danger",
        MovementType.In => "bg-success",
        MovementType.Reserve => "bg-info text-dark",
        MovementType.Restore => "bg-primary",
        _ => "bg-secondary"
    };
}
