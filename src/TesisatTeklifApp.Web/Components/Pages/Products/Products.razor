@page "/products"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IProductService ProductService
@inject NavigationManager Nav

<PageTitle>Ürünler</PageTitle>

<div class="d-flex align-items-center mb-3">
    <h2 class="mb-0">Ürün / Malzeme Yönetimi</h2>
    <AuthorizeView Roles="Admin" Context="a">
        <div class="ms-auto d-flex gap-2">
            <a href="products/bulk" class="btn btn-outline-success">📊 Toplu Excel</a>
            <a href="products/new" class="btn btn-primary">➕ Yeni Ürün</a>
        </div>
    </AuthorizeView>
</div>

<div class="card summary-box mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-4">
                <input class="form-control" placeholder="Ara: ad / marka / model" @bind="filter.Keyword" @bind:event="oninput" />
            </div>
            <div class="col-md-3">
                <select class="form-select" @bind="filter.Category">
                    <option value="">Tüm kategoriler</option>
                    @foreach (var c in ProductCategories.All)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-center">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="crit" @bind="filter.OnlyCriticalStock" />
                    <label class="form-check-label" for="crit">Sadece kritik stok</label>
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100" @onclick="Load">Filtrele</button>
            </div>
        </div>
    </div>
</div>

<div class="alert @(canReorder ? "alert-success" : "alert-secondary") py-2 small d-flex align-items-center">
    <i class="bi bi-arrows-move me-2"></i>
    @if (canReorder)
    {
        <span>Satırları <strong>sürükleyerek</strong> veya <strong>⤒</strong> ile sıralayabilirsiniz. Bu sıra teklif formundaki ürün listesine de yansır.</span>
    }
    else
    {
        <span>Sıralama yapmak için yukarıdan bir <strong>kategori seçip Filtrele</strong>'ye basın (sıra kategori içinde tutulur).</span>
    }
    @if (!string.IsNullOrEmpty(orderMsg))
    {
        <span class="ms-auto text-success fw-semibold">@orderMsg</span>
    }
</div>

<div class="card summary-box">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead>
                <tr>
                    <AuthorizeView Roles="Admin" Context="d"><th style="width:34px"></th></AuthorizeView>
                    <th>Ad</th><th>Kategori</th><th>Marka/Model</th><th>Birim</th>
                    <th class="text-end">Satış ₺</th><th class="text-end">Stok</th><th>Durum</th>
                    <AuthorizeView Roles="Admin" Context="a"><th></th></AuthorizeView>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in items)
                {
                    @* Sıralama yalnızca BIRAKINCA yapılır; sürükleme sırasında sadece hedef
                       satır vurgulanır. (Sürüklerken yeniden sıralamak, ondragover saniyede
                       onlarca kez tetiklendiği için satırların sekmesine yol açıyordu.) *@
                    <tr class="@RowClass(p) @(dragId == p.Id ? "row-dragging" : "") @(overId == p.Id && dragId != p.Id ? "row-drop-target" : "")"
                        draggable="@canReorder.ToString().ToLowerInvariant()"
                        @ondragstart="() => DragStart(p)"
                        @ondragenter="() => overId = p.Id"
                        @ondragover:preventDefault="true"
                        @ondragend="DragEnd"
                        @ondrop:preventDefault="true"
                        @ondrop="() => DropOn(p)"
                        @key="p.Id">
                        <AuthorizeView Roles="Admin" Context="d">
                            <td class="drag-cell" title="Sürükleyip sırala">
                                <i class="bi bi-grip-vertical text-muted"></i>
                            </td>
                        </AuthorizeView>
                        <td>@p.Name</td>
                        <td>@p.Category</td>
                        <td>@p.Brand @p.Model</td>
                        <td>@p.Unit</td>
                        <td class="text-end">@p.SalePrice.ToString("#,##0.00")</td>
                        <td class="text-end">@(p.IsStockTracked ? FormatQty(p.StockQuantity) : "-")</td>
                        <td>@StockLabel(p)</td>
                        <AuthorizeView Roles="Admin" Context="a">
                            <td class="text-end text-nowrap">
                                <button class="btn btn-sm btn-outline-primary" title="En üste al"
                                        @onclick="() => MoveToTop(p)">⤒</button>
                                <a href="products/@p.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                            </td>
                        </AuthorizeView>
                    </tr>
                }
                @if (items.Count == 0)
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">Kayıt bulunamadı.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private ProductSearchFilter filter = new();
    private List<Product> items = new();

    // --- Sıralama (sürükle-bırak) ---
    private int? dragId;    // sürüklenen satır
    private int? overId;    // üzerinde durulan satır (sadece vurgu)
    private string? orderMsg;

    // Sıra kategori içinde tutulduğu için yalnızca tek kategori süzülüyken sürükleme anlamlı.
    private bool canReorder => !string.IsNullOrWhiteSpace(filter.Category);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        items = await ProductService.SearchAsync(filter);
        dragId = null;
    }

    private void DragStart(Product p) { if (canReorder) dragId = p.Id; }

    private void DragEnd() { dragId = null; overId = null; }

    /// <summary>Sürüklenen satırı, bırakılan satırın konumuna taşır ve kaydeder.</summary>
    private async Task DropOn(Product target)
    {
        var moving = dragId;
        DragEnd();
        if (!canReorder || moving is null || moving == target.Id) return;

        var from = items.FindIndex(x => x.Id == moving);
        var to = items.FindIndex(x => x.Id == target.Id);
        if (from < 0 || to < 0 || from == to) return;

        var row = items[from];
        items.RemoveAt(from);
        items.Insert(to, row);
        await PersistOrder();
    }

    private async Task MoveToTop(Product p)
    {
        if (!canReorder)
        {
            orderMsg = "Sıralamak için önce bir kategori seçin.";
            return;
        }
        var i = items.FindIndex(x => x.Id == p.Id);
        if (i <= 0) return;
        items.RemoveAt(i);
        items.Insert(0, p);
        await PersistOrder();
    }

    private async Task PersistOrder()
    {
        await ProductService.SaveOrderAsync(items.Select(x => x.Id).ToList());
        orderMsg = "Sıralama kaydedildi.";
    }

    private string RowClass(Product p)
    {
        if (!p.IsStockTracked) return "";
        if (p.StockQuantity <= 0) return "stock-insufficient";
        if (p.StockQuantity <= p.CriticalStockQuantity) return "stock-critical";
        return "";
    }

    private string StockLabel(Product p)
    {
        if (!p.IsStockTracked) return "Takipsiz";
        if (p.StockQuantity <= 0) return "Yetersiz";
        if (p.StockQuantity <= p.CriticalStockQuantity) return "Kritik";
        return "Yeterli";
    }

    private static string FormatQty(decimal q) => q % 1 == 0 ? q.ToString("0") : q.ToString("0.##");
}
