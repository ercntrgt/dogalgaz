@page "/products/bulk"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IProductService ProductService

<PageTitle>Toplu Stok / Fiyat (Excel)</PageTitle>

<h2 class="mb-3">Toplu Stok &amp; Fiyat Güncelleme (Excel)</h2>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card summary-box h-100">
            <div class="card-header bg-white fw-semibold">1) Şablonu indir</div>
            <div class="card-body">
                <p class="text-muted">Mevcut tüm ürünleri Excel olarak indir, fiyat/stok sütunlarını düzenle.</p>
                <a class="btn btn-outline-success" href="/download/products/template" target="_blank">⬇️ Excel Şablonunu İndir</a>
                <ul class="small text-muted mt-3 mb-0">
                    <li><strong>Id</strong> sütununu değiştirme — eşleştirme buna göre yapılır.</li>
                    <li>Yeni ürün eklemek için <strong>Id'yi boş bırak</strong>, satırı doldur.</li>
                    <li>Stok değişirse otomatik <strong>stok hareketi</strong> oluşturulur.</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card summary-box h-100">
            <div class="card-header bg-white fw-semibold">2) Doldurulmuş dosyayı yükle</div>
            <div class="card-body">
                <label class="btn btn-primary mb-2">
                    📤 Excel Yükle ve Güncelle
                    <InputFile OnChange="OnFileSelected" accept=".xlsx" hidden />
                </label>
                @if (busy) { <div class="text-muted small">İşleniyor...</div> }

                @if (result is not null)
                {
                    <div class="alert @(result.HasErrors ? "alert-warning" : "alert-success") mt-2">
                        <div>✓ Güncellenen ürün: <strong>@result.UpdatedCount</strong></div>
                        <div>📦 Stok değişen: <strong>@result.StockChangedCount</strong></div>
                        @if (result.NotFoundCount > 0) { <div>⚠️ Bulunamayan Id: @result.NotFoundCount</div> }
                    </div>
                    @if (result.Notes.Count > 0)
                    {
                        <details class="small"><summary>Notlar (@result.Notes.Count)</summary>
                            <ul>@foreach (var n in result.Notes) { <li>@n</li> }</ul>
                        </details>
                    }
                    @if (result.Errors.Count > 0)
                    {
                        <div class="text-danger small mt-2"><strong>Hatalar:</strong>
                            <ul>@foreach (var e in result.Errors) { <li>@e</li> }</ul>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3"><a href="products" class="btn btn-link">← Ürünlere dön</a></div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private bool busy;
    private BulkImportResult? result;
    private const long MaxBytes = 8 * 1024 * 1024;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        busy = true; result = null;
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(MaxBytes).CopyToAsync(ms);
            var user = AuthState is null ? null : (await AuthState).User.Identity?.Name;
            result = await ProductService.ImportProductsExcelAsync(ms.ToArray(), user);
        }
        catch (Exception ex)
        {
            result = new BulkImportResult();
            result.Errors.Add(ex.Message);
        }
        finally { busy = false; }
    }
}
