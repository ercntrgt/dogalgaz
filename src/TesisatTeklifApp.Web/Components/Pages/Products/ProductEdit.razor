@page "/products/new"
@page "/products/{Id:int}"
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IProductService ProductService
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Yeni Ürün" : "Ürün Düzenle")</PageTitle>

<h2 class="mb-3">@(IsNew ? "Yeni Ürün" : $"Ürün Düzenle: {model.Name}")</h2>

@if (model is null)
{
    <p>Yükleniyor...</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <div class="card summary-box">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Ürün Adı *</label>
                        <InputText class="form-control" @bind-Value="model.Name" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Kategori *</label>
                        <InputSelect class="form-select" @bind-Value="model.Category">
                            @foreach (var c in ProductCategories.All)
                            {
                                <option value="@c">@c</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Birim</label>
                        <InputText class="form-control" @bind-Value="model.Unit" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Marka</label>
                        <InputText class="form-control" @bind-Value="model.Brand" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Model</label>
                        <InputText class="form-control" @bind-Value="model.Model" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Alış Fiyatı ₺</label>
                        <InputNumber class="form-control" @bind-Value="model.PurchasePrice" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Satış Fiyatı ₺ *</label>
                        <InputNumber class="form-control" @bind-Value="model.SalePrice" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">KDV %</label>
                        <InputNumber class="form-control" @bind-Value="model.VatRate" />
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Açıklama</label>
                        <InputText class="form-control" @bind-Value="model.Description" />
                    </div>
                    <div class="col-12"><hr /><h6>Stok Bilgileri</h6></div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" id="tracked" @bind-Value="model.IsStockTracked" />
                            <label class="form-check-label" for="tracked">Stok takibi yapılsın</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Mevcut Stok</label>
                        <InputNumber class="form-control" @bind-Value="model.StockQuantity" disabled="@(!model.IsStockTracked)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Kritik Stok Seviyesi</label>
                        <InputNumber class="form-control" @bind-Value="model.CriticalStockQuantity" disabled="@(!model.IsStockTracked)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Minimum Stok</label>
                        <InputNumber class="form-control" @bind-Value="model.MinimumStockQuantity" disabled="@(!model.IsStockTracked)" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" id="active" @bind-Value="model.IsActive" />
                            <label class="form-check-label" for="active">Aktif</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2">
                <button type="submit" class="btn btn-success">💾 Kaydet</button>
                <a href="products" class="btn btn-outline-secondary">İptal</a>
                @if (!IsNew)
                {
                    <button type="button" class="btn btn-outline-danger ms-auto" @onclick="Delete">🗑 Sil</button>
                }
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => Id is null;
    private Product model = new() { Category = ProductCategories.Kombi, Unit = "Adet", VatRate = 20m, IsActive = true, IsStockTracked = true };

    protected override async Task OnParametersSetAsync()
    {
        if (Id is int id)
            model = await ProductService.GetByIdAsync(id) ?? model;
    }

    private async Task Save()
    {
        if (IsNew) await ProductService.AddAsync(model);
        else await ProductService.UpdateAsync(model);
        Nav.NavigateTo("products");
    }

    private async Task Delete()
    {
        if (Id is int id) { await ProductService.SoftDeleteAsync(id); Nav.NavigateTo("products"); }
    }
}
